local glideDebounce = false

UIS.InputBegan:Connect(function(input, gp)

	if gp then return end
	if not glideEnabled then return end

	if input.KeyCode == Enum.KeyCode.Space then

		if glideDebounce then return end
		glideDebounce = true

		if not mHum or not mRoot then
			glideDebounce = false
			return
		end

		local moveDir = mHum.MoveDirection

		if moveDir.Magnitude > 0 then

			local bv = Instance.new("BodyVelocity")

			bv.MaxForce = Vector3.new(90000,0,90000)

			bv.Velocity =
				(moveDir * (glidePower * 12))

			bv.Parent = mRoot

			game:GetService("Debris"):AddItem(bv, 0.12)
		end

		task.delay(0.15, function()
			glideDebounce = false
		end)
	end
end)

