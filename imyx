local function getRemote()
	local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
	if not character then return end

	local rootPart = character:FindFirstChild("HumanoidRootPart")
	local rightHand = character:FindFirstChild("RightHand")
	local core = character:FindFirstChild("Core")
	if not rootPart or not rightHand or not core then return end

	return core:FindFirstChild("Communicate"):FindFirstChildOfClass("RemoteEvent")
end

local flingEnabled = false
local fakePart, attachment1, attachment2, alignPosition, particle
local flingConnections = {}
local originalPosition = nil
local distanceCheckConnection = nil

local function stopFling()
	flingEnabled = false
	for _, conn in pairs(flingConnections) do
		if typeof(conn) == 'RBXScriptConnection' then
			conn:Disconnect()
		elseif typeof(conn) == 'Instance' and conn:IsA('Instance') then
			conn:Destroy()
		end
	end
	table.clear(flingConnections)
	if fakePart then
		fakePart:Destroy()
		fakePart = nil
	end
	if
		LocalPlayer.Character
		and LocalPlayer.Character:FindFirstChild('HumanoidRootPart')
	then
		local hrp = LocalPlayer.Character.HumanoidRootPart
		hrp.AssemblyLinearVelocity = Vector3.zero
		hrp.AssemblyAngularVelocity = Vector3.zero
		if originalPosition then
			hrp.CFrame = originalPosition
		end
	end
	if distanceCheckConnection then
		distanceCheckConnection:Disconnect()
		distanceCheckConnection = nil
	end
end

local function startFling(targetHRP)
	local localHRP = LocalPlayer.Character
		and LocalPlayer.Character:FindFirstChild('HumanoidRootPart')
	if not localHRP or not targetHRP then
		return
	end

	flingEnabled = true
	originalPosition = localHRP.CFrame

	fakePart = Instance.new('Part')
	fakePart.Size = Vector3.new(4, 4, 4)
	fakePart.Transparency = 1 
	fakePart.Anchored = false
	fakePart.CanCollide = false
	fakePart.Position = localHRP.Position
	fakePart.Parent = workspace

	attachment1 = Instance.new('Attachment', fakePart)
	attachment2 = Instance.new('Attachment', localHRP)
	alignPosition = Instance.new('AlignPosition', fakePart)
	alignPosition.Attachment0 = attachment2
	alignPosition.Attachment1 = attachment1
	alignPosition.RigidityEnabled = true
	alignPosition.Responsiveness = 200
	alignPosition.MaxForce = math.huge
	alignPosition.MaxVelocity = math.huge

	local predictionMultiplier = 0.1

	table.insert(
		flingConnections,
		RunService.Heartbeat:Connect(function()
			if not flingEnabled then
				return
			end
			if
				not (
					LocalPlayer.Character
						and LocalPlayer.Character:FindFirstChild('HumanoidRootPart')
						and targetHRP
				)
			then
				return
			end

			local predictedPos = targetHRP.Position
				+ targetHRP.Velocity * predictionMultiplier
			local predictedCFrame = CFrame.new(
				predictedPos,
				predictedPos + targetHRP.CFrame.LookVector
			)

			localHRP.CFrame = predictedCFrame
			localHRP.AssemblyLinearVelocity =
				Vector3.new(5000, 1500, -5000)
			localHRP.AssemblyAngularVelocity =
				Vector3.new(8000, 12000, -12000)

		end)
	)

	distanceCheckConnection = RunService.Heartbeat:Connect(function()
		if
			LocalPlayer.Character
			and LocalPlayer.Character:FindFirstChild('HumanoidRootPart')
			and originalPosition
		then
			local dist = (
				LocalPlayer.Character.HumanoidRootPart.Position
				- originalPosition.Position
			).Magnitude
			if dist >= 1000 then
				stopFling()
			end
		end
	end)
end

