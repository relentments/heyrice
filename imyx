headlessCorner.CornerRadius = UDim.new(0,8)
headlessCorner.Parent = headlessBtn

-- TOGGLE
headlessBtn.MouseButton1Click:Connect(function()

	headlessEnabled = not headlessEnabled

	if headlessEnabled then

		local char = lp.Character

		if char then
			applyLocalHeadless(char)
		end

		remote:FireServer()

		headlessBtn.Text = "Headless: ON"
		headlessBtn.BackgroundColor3 = THEME.On

	else

		headlessBtn.Text = "Headless: OFF"
		headlessBtn.BackgroundColor3 = Color3.fromRGB(0,0,0)

		local char = lp.Character

		if char then

			local head = char:FindFirstChild("Head")

			if head then
				head.Transparency = 0

				for _,v in pairs(head:GetChildren()) do
					if v:IsA("Decal") then
						v.Transparency = 0
					end
				end
			end

			for _,acc in pairs(char:GetChildren()) do
				if acc:IsA("Accessory") then

					local handle = acc:FindFirstChild("Handle")

					if handle then
						handle.Transparency = 0
					end
				end
			end
		end
	end
end)

-- REAPPLY AFTER RESPAWN
lp.CharacterAdded:Connect(function(char)

	if headlessEnabled then

		task.wait(1)

		applyLocalHeadless(char)

		remote:FireServer()
	end
end)

-- ANTI DESYNC CLEANER
task.spawn(function()

	while task.wait(5) do

		if mRoot then

			mRoot.AssemblyLinearVelocity *= 0.85

		end
	end
end)

print("[SleepParalysis v4.8] Loaded - Headless button disappears after use | Insert / RightShift")
