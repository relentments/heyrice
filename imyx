local function setupAnimator(character)
	local humanoid = character:WaitForChild("Humanoid")
	local animator = humanoid:FindFirstChildOfClass("Animator") or Instance.new("Animator", humanoid)

	if animPlayedConn then animPlayedConn:Disconnect() end
	if fastPunchConn then fastPunchConn:Disconnect() end

	tracked = {}

	animPlayedConn = animator.AnimationPlayed:Connect(function(track)
		pcall(function()
			if validNames[track.Name] then
				tracked[track] = true
				track:AdjustSpeed(FastPunchSlider.Value)
			end
		end)
	end)

	fastPunchConn = RunService.Heartbeat:Connect(function()
		pcall(function()
			for track in pairs(tracked) do
				if track.IsPlaying then
					track:AdjustSpeed(FastPunchSlider.Value)
				else
					tracked[track] = nil
				end
			end
		end)
	end)
end

