			v.Material = Enum.Material.SmoothPlastic
			v.Reflectance = 0
		end

		if v:IsA("Decal") or v:IsA("Texture") then
			v.Transparency = 1
		end

		if v:IsA("ParticleEmitter")
			or v:IsA("Trail")
			or v:IsA("Smoke")
			or v:IsA("Fire")
			or v:IsA("Sparkles") then

