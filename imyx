-- ─── Hitbox - improved (only alive & not knocked) ─────────────

local whitelist = {}
local originalHRP = {}

local function UpdateHitboxes()
	if not hbEnabled() then return end

	local sizeVal   = Vector3.new(hbSize, hbSize, hbSize)
	local transVal  = hbTransEnabled() and hbTrans or 0

	for _, plr in pairs(Players:GetPlayers()) do
		if plr == lp then continue end
		local char = plr.Character
		if not char then continue end

		local root = char:FindFirstChild("HumanoidRootPart")
		if not root then continue end

		if whitelist[plr] then
			if not originalHRP[plr] then
				originalHRP[plr] = {
					Size = root.Size,
					Transparency = root.Transparency,
					CanCollide = root.CanCollide,
					CanQuery = root.CanQuery,
				}
			end

			root.Size         = sizeVal
			root.Transparency = transVal
			root.CanCollide   = false
			root.CanQuery     = true

			for _, p in pairs(char:GetChildren()) do
				if p:IsA("BasePart") then
					p.CanCollide = false
					p.CanQuery   = true
				end
			end
		else
			local props = originalHRP[plr]
			if props then
				root.Size         = props.Size
				root.Transparency = props.Transparency
				root.CanCollide   = props.CanCollide
				root.CanQuery     = props.CanQuery
			end
		end
	end
end

local function evaluateShouldExpand(plr)
	if not plr then return end

	local char = plr.Character
	local hum  = char and char:FindFirstChildOfClass("Humanoid")
	if not hum or hum.Health <= 0 then
		whitelist[plr] = nil
		return
	end

	local live = workspace:FindFirstChild("Live")
	if not live then return end

	local entry = live:FindFirstChild(plr.Name)
	if not entry then return end

	local knocked = entry:FindFirstChild("Knocked")
	if knocked and knocked:IsA("BoolValue") and knocked.Value then
		whitelist[plr] = nil
	else
		whitelist[plr] = true
	end
end

local function monitorPlayer(plr)
	if plr == lp then return end

	local function onCharAdded(char)
		task.wait(0.2)
		evaluateShouldExpand(plr)
		UpdateHitboxes()

		local hum = char:WaitForChild("Humanoid", 8)
		if hum then
			hum.HealthChanged:Connect(function()
				evaluateShouldExpand(plr)
				UpdateHitboxes()
			end)
			hum.Died:Connect(function()
				whitelist[plr] = nil
				UpdateHitboxes()
			end)
		end
	end

	plr.CharacterAdded:Connect(onCharAdded)
	if plr.Character then onCharAdded(plr.Character) end
end

local function setupLiveWatcher()
	local live = workspace:FindFirstChild("Live")
	if not live then
		workspace.ChildAdded:Connect(function(ch)
			if ch.Name == "Live" then setupLiveWatcher() end
		end)
		return
	end

	live.ChildAdded:Connect(function(entry)
		local plr = Players:FindFirstChild(entry.Name)
		if not plr then return end

		local knocked = entry:WaitForChild("Knocked", 5)
		if knocked and knocked:IsA("BoolValue") then
			knocked.Changed:Connect(function()
				evaluateShouldExpand(plr)
				UpdateHitboxes()
			end)
		end

		evaluateShouldExpand(plr)
		UpdateHitboxes()
	end)

	for _, entry in pairs(live:GetChildren()) do
		local plr = Players:FindFirstChild(entry.Name)
		if plr then
			local knocked = entry:FindFirstChild("Knocked")
			if knocked and knocked:IsA("BoolValue") then
				knocked.Changed:Connect(function()
					evaluateShouldExpand(plr)
					UpdateHitboxes()
				end)
			end
			evaluateShouldExpand(plr)
		end
	end
end

setupLiveWatcher()

for _, plr in pairs(Players:GetPlayers()) do
	monitorPlayer(plr)
end

